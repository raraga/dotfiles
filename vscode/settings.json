{
    "editor.fontFamily": "MonoLisa",
    "editor.fontSize": 16,
    "terminal.integrated.fontSize": 16,
    "editor.fontLigatures": true,
    "editor.lineNumbers": "off",
    "editor.renderLineHighlight": "none",
    "editor.guides.indentation": false,
    "editor.scrollbar.vertical": "hidden",
    "workbench.sideBar.location": "right",
    "workbench.editor.enablePreview": false,
    "window.menuBarVisibility": "toggle",
    "vim.insertModeKeyBindings": [
        { "before": ["j", "j"], "after": ["<Esc>"] },                                                                                      
        { "before": ["j", "k"], "after": ["<Esc>"] }  
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        { "before": ["g", "n"], "commands": [":tabnext"] },
        { "before": ["g", "p"], "commands": [":tabprev"] },
        { "before": ["g", "o"], "commands": [":tabonly"] },
        { "before": ["g", "t"], "commands": [":tabclose"] },
        { "before": ["<Leader>", "p"], "commands": ["workbench.action.showCommands"] },
        { "before": ["<Leader>", "f"], "commands": ["workbench.action.quickOpen"] },
        { "before": ["<Leader>", "x"], "commands": ["workbench.view.extensions"] },
        { "before": ["<Leader>", "a"], "commands": ["workbench.action.showEditorsInActiveGroup"] },
    ],
    "vim.leader": "<space>",
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },
    "workbench.startupEditor": "none",
    "intelephense.licenceKey": "00W1X5NRP9VF6N1",
    "terminal.integrated.tabs.location": "left",
    "terminal.integrated.tabs.enabled": false,
    "breadcrumbs.enabled": false,
    "editor.minimap.enabled": false,
    "workbench.activityBar.location": "hidden",
    "editor.stickyScroll.enabled": false,
    "window.customTitleBarVisibility": "windowed",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "workbench.editor.editorActionsLocation": "hidden",
    "better-pest.docker.enable": true,
    "better-pest.docker.command": "docker-compose run --rm laravel.test sail",
    "better-pest.docker.paths": {
        "${workspaceFolder}": "/var/www/html"
    },
    "Laravel.phpEnvironment": "sail",
    "workbench.colorTheme": "Solarized Dark",
    "workbench.editor.showTabs": "none",
    "workbench.colorCustomizations": {
        "editorCursor.foreground": "#d33682",
        "editorCursor.background": "#073642",
        "terminalCursor.foreground": "#d33682"
    }
}